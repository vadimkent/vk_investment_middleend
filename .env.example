PORT=8080
LOG_LEVEL=info
LOG_FORMAT=json
BACKEND_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
REQUEST_TIMEOUT=30s
# Must match the backend's JWT_SECRET (HS256 shared secret used to verify tokens)
JWT_SECRET=dev-secret-change-me
JWT_LEEWAY_SECONDS=30
# When true, /actions/analysis/stream and /actions/analysis/sessions/:id/messages
# return a synthetic SSE response (canned markdown chunked into deltas) instead
# of calling the backend's AI provider. Use during dev to avoid burning tokens.
ANALYSIS_FAKE=false
